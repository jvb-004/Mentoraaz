# ── Required ──────────────────────────────────────────────────────────────────
# Secret used to sign login sessions — generate any long random string
JWT_SECRET=change-this-to-a-long-random-string

# Your email — gives you access to /admin panel
ADMIN_EMAILS=you@example.com

# ── Email verification (Resend) ───────────────────────────────────────────────
# Without this, verification links are printed to the terminal (dev mode)
# Get a free key at resend.com — 100 emails/day free
RESEND_API_KEY=

# The email address users see as the sender
FROM_EMAIL=Mentora <noreply@mentora.az>

# Your site's public URL — used in email links
APP_URL=http://localhost:5173

# ── Google Sign-In ────────────────────────────────────────────────────────────
# Without this, Google Sign-In button is hidden
# Steps:
#   1. Go to console.cloud.google.com
#   2. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
#   3. Application type: Web application
#   4. Authorized origins: http://localhost:5173 (and your live domain later)
#   5. Paste the Client ID here AND in frontend/.env
GOOGLE_CLIENT_ID=

# ── Payments (Stripe) ────────────────────────────────────────────────────────
# Without this, payments use a mock path (fully testable, no real money)
# Note: Stripe does not yet support Azerbaijan-based businesses directly
# Options: Stripe Atlas (US company) or a local AZ payment gateway
STRIPE_SECRET_KEY=

PORT=4000
NODE_ENV=development
