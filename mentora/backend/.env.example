# Copy this to .env and fill in real values before deploying

# Required: secret used to sign login sessions - generate a long random string
JWT_SECRET=change-this-to-a-long-random-string

# Optional: comma-separated emails allowed to access /api/admin/* routes
ADMIN_EMAILS=you@example.com

# Optional: only needed once you have a real Stripe-supported business entity.
# Without this, boosts/subscriptions use a working mock-payment path so you can
# fully test and demo the product right now.
STRIPE_SECRET_KEY=

PORT=4000
NODE_ENV=development
